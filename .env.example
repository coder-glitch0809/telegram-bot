# Gmail ishlatsangiz, SMTP_PASSWORD oddiy parol emas, App Password bo'lishi kerak.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=sizning_emailingiz@gmail.com
SMTP_PASSWORD=PASTE_EMAIL_APP_PASSWORD_HERE
SMTP_FROM_EMAIL=sizning_emailingiz@gmail.com

# 0=dushanba, 1=seshanba, ..., 6=yakshanba.
REPORT_WEEKLY_DAY=0

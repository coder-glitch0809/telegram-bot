# =========================
# ASOSIY API KALITLAR SHU YERDA
# =========================
# 1) Telegram bot tokeni. Buni @BotFather dan olasiz.
TELEGRAM_BOT_TOKEN=7147060630:AAGd92-XAM5tk5W7hQolAEQrK8YttClV2p0

# 2) Gemini AI API key.
# Google AI Studio dan olinadi: https://aistudio.google.com/app/apikey

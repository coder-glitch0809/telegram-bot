# =========================
# GOOGLE SHEETS SOZLAMALARI
# =========================
# Google Cloud service account JSON fayli yo'li.
# Masalan: D:\projects\telegram bot\google-service-account.json
GOOGLE_SERVICE_ACCOUNT_FILE=telegram-bot-projekt-2cb77494cb53.json

# Vercelda JSON fayl commit qilinmaydi, shuning uchun service account JSON ni
# bitta qatorda Environment Variable qilib qo'yish mumkin.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Ixtiyoriy: yaratilgan spreadsheetlarni bitta Google Drive papkaga joylash.
# Papka ID linkdagi /folders/ dan keyingi qism bo'ladi.
GOOGLE_DRIVE_PARENT_FOLDER_ID=1C4NLS1SsMlRrGIhoXzJtfBcJDfwZdFFW

# Ixtiyoriy: yaratilgan spreadsheetlarni shu emailga ulashish.
SHARE_SPREADSHEET_WITH_EMAIL=ximoyachilar@gmail.com

# =========================
# BOT EGASI / XARAJAT RUXSATI
# =========================
# Faqat shu Telegram user ID lar xarajat yozishi mumkin.
# O'zingizning ID ingizni topish uchun botga /start yozing.
# Bir nechta ID bo'lsa vergul bilan yozing: 123,456
EXPENSE_ALLOWED_USER_IDS=896778319

# AI model sozlamalari.
OPENAI_TEXT_MODEL=grok-4.20-reasoning
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# =========================
# EMAIL HISOBOT SOZLAMALARI
# =========================
# Bot foydalanuvchilarni lokal SQLite bazaga yozadi.
ANALYTICS_DB_FILE=bot_analytics.sqlite3

# Hisobot yuboriladigan email.
OWNER_EMAIL=sizning_emailingiz@gmail.com

# Gmail ishlatsangiz, SMTP_PASSWORD oddiy parol emas, App Password bo'lishi kerak.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=sizning_emailingiz@gmail.com
SMTP_PASSWORD=PASTE_EMAIL_APP_PASSWORD_HERE
